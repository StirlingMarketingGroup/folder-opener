<?xml version="1.0" encoding="UTF-8"?>
<!-- Per-machine MSI, GPO-deployable. Autostart for all users via an HKLM Run
     value so no per-user setup is needed after a domain push. -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="Folder Opener"
           Manufacturer="Stirling Marketing Group"
           Version="$(var.Version)"
           UpgradeCode="0F50471E-B120-4843-A7C1-407B70967C4E"
           Scope="perMachine"
           Compressed="yes">
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of Folder Opener is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Folder Opener">
        <Component Id="MainExe">
          <File Id="FolderOpenerExe" Source="folder-opener.exe" KeyPath="yes" />
        </Component>
        <Component Id="RunKey" Guid="1E1A47B4-6B21-4A4C-9C8A-AE208804F990">
          <RegistryValue Root="HKLM"
                         Key="Software\Microsoft\Windows\CurrentVersion\Run"
                         Name="Folder Opener"
                         Type="string"
                         Value="&quot;[INSTALLFOLDER]folder-opener.exe&quot;"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Folder Opener">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="RunKey" />
    </Feature>

    <!-- The tray app locks its own exe; terminate the running instance during
         upgrades/uninstalls so the MSI never shows a files-in-use/reboot
         prompt. It's a stateless localhost server — killing it is safe, and
         LaunchApp starts the new version right back up. -->
    <util:CloseApplication Id="CloseFolderOpener"
                           Target="folder-opener.exe"
                           CloseMessage="no"
                           RebootPrompt="no"
                           TerminateProcess="0" />

    <!-- Launch immediately after install/upgrade so there's zero manual setup:
         install the MSI and the server is running. Launched via explorer.exe
         rather than directly: this action runs in the elevated execute
         sequence, so a direct launch keeps the installer's identity (the
         admin account typed at the UAC prompt, or an IT remote-assist
         session) — and the server then authenticates to network shares as
         THAT account, denying folders the signed-in user can open manually.
         Explorer hands the launch to the session shell, so the server runs
         as the actual desktop user.

         UILevel >= 4 restricts the launch to interactive installs. A GPO
         machine install at boot runs silently (UILevel 2) as SYSTEM in
         session 0, where there is NO shell to hand off to — explorer.exe
         just runs the exe itself, leaving a server that answers on the port
         but opens Explorer windows on session 0's invisible desktop (and
         blocks the user's logon copy from binding the port). Silent installs
         rely on the HKLM Run value starting the server at each user's next
         logon instead. The server also refuses to run in session 0 as a
         second line of defense. -->
    <CustomAction Id="LaunchApp"
                  Directory="INSTALLFOLDER"
                  ExeCommand='[WindowsFolder]explorer.exe "[INSTALLFOLDER]folder-opener.exe"'
                  Return="asyncNoWait" />
    <InstallExecuteSequence>
      <Custom Action="LaunchApp" After="InstallFinalize" Condition="NOT REMOVE AND UILevel &gt;= 4" />
    </InstallExecuteSequence>
  </Package>
</Wix>
